# Copie ce fichier en .env et remplis tes vraies valeurs
# Ces infos viennent de ton projet Supabase (Settings > API)

SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL de ton frontend (pour autoriser les connexions)
# En développement local : http://localhost:5173
# En production : https://ton-app.vercel.app
FRONTEND_URL=http://localhost:5173

# Port du serveur (Railway le définit automatiquement)
PORT=3001
